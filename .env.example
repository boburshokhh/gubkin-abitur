# ============================================================
# Root .env example
# Used by Vite frontend and docker compose variable interpolation.
# Copy to .env and replace secrets before production deploy.
# ============================================================

# ----------------------------
# Frontend
# ----------------------------
# Browser API base URL.
# Local frontend dev: http://localhost:3000/api
# Docker frontend through nginx/proxy: /api
# Production example: https://your-domain.uz/api
VITE_API_URL=http://localhost:3000/api

# Controls whether application submission UI is visible.
VITE_ADMISSION_OPEN=false

# Controls backend API access to public signup and new applications.
ADMISSION_OPEN=false

# ----------------------------
# Backend public origin / CORS
# ----------------------------
# Must match the public frontend origin that opens the site in browser.
# Local Vite: http://localhost:5173
# Docker local: http://localhost:8085
# Production example: https://your-domain.uz
FRONTEND_ORIGIN=http://localhost:8085

# ----------------------------
# Auth security
# ----------------------------
# Generate strong random values before production:
# openssl rand -base64 48
JWT_SECRET=replace-with-strong-random-jwt-secret
TOKEN_PEPPER=replace-with-strong-random-token-pepper

# Access token lifetime in seconds. Recommended: 10-15 minutes.
ACCESS_TOKEN_TTL_SECONDS=900

# Refresh/session lifetime in days.
REFRESH_TOKEN_TTL_DAYS=30

# One-time email verification token lifetime in minutes.
EMAIL_TOKEN_TTL_MINUTES=1440

# Password reset token lifetime in minutes.
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Invitation link lifetime in days.
INVITATION_TOKEN_TTL_DAYS=7

# ----------------------------
# SMTP mailer
# ----------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=true
SMTP_USER=noreply@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=noreply@example.com

# ----------------------------
# Docker database
# ----------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=abitur

# Backend container uses db service hostname.
DATABASE_URL=postgresql://postgres:postgrespassword@db:5432/abitur

# ----------------------------
# Docker MinIO / S3
# На старых VPS (CPU без x86-64-v2) в docker-compose используется образ ...-cpuv1.
# ВАЖНО: MINIO_ROOT_USER/PASSWORD и S3_ACCESS_KEY/SECRET_KEY должны совпадать!
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadminpassword
# Если в пароле есть @ : / # ? — URL-кодируйте его в MC_HOST_local (см. docker-compose.yml).
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadminpassword
S3_BUCKET_DOCUMENTS=application-documents
S3_BUCKET_FILES=application-files
