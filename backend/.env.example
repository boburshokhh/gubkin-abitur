# ============================================================
# Backend .env example
# Used when running backend locally from ./backend.
# Copy to backend/.env and replace secrets before production.
# ============================================================

# ----------------------------
# Server
# ----------------------------
NODE_ENV=development
PORT=3000

# Frontend origin allowed by CORS.
FRONTEND_ORIGIN=http://localhost:5173

# ----------------------------
# PostgreSQL
# ----------------------------
# Local host port from docker-compose maps PostgreSQL to 5434.
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5434/abitur

# If you use a local PostgreSQL server outside docker, use:
# DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/abitur

# ----------------------------
# Auth security
# ----------------------------
# Generate strong random values before production:
# openssl rand -base64 48
JWT_SECRET=replace-with-strong-random-jwt-secret
TOKEN_PEPPER=replace-with-strong-random-token-pepper

ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_TOKEN_TTL_MINUTES=1440
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
INVITATION_TOKEN_TTL_DAYS=7

# ----------------------------
# SMTP mailer
# ----------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=true
SMTP_USER=noreply@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=noreply@example.com

# Настройки S3 (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadminpassword
S3_BUCKET_DOCUMENTS=application-documents
S3_BUCKET_FILES=application-files
